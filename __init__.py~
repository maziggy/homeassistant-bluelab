import logging
from homeassistant.helpers.event import async_track_time_interval
from .const import DOMAIN, TELEMETRY_UPDATE_INTERVAL

_LOGGER = logging.getLogger(__name__)

async def async_update_telemetry(hass, entry):
    """Fetch telemetry data from the API and update entities."""
    devices = hass.data[DOMAIN][entry.entry_id]["devices"]
    telemetry_data = []
    for device in devices:
        telemetry = await fetch_device_telemetry(device["id"])
        telemetry_data.append(telemetry)
    _LOGGER.debug("Telemetry data updated for devices: %s", telemetry_data)

async def async_setup_entry(hass, entry):
    """Set up Bluelab Guardian from a config entry."""
    api_token = entry.data["api_token"]
    hass.data.setdefault(DOMAIN, {})
    hass.data[DOMAIN][entry.entry_id] = {
        "api_token": api_token,
        "devices": await fetch_devices(api_token),
    }
    async_track_time_interval(hass, lambda now: hass.async_create_task(async_update_telemetry(hass, entry)), TELEMETRY_UPDATE_INTERVAL)
    return True

